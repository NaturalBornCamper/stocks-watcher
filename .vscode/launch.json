{
    // Mirrors .idea/runConfigurations/*.xml -- folderName attributes map to presentation.group here.
    // Keep these two files in sync (see CLAUDE.md "Run Configurations").
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Dev Server",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "runserver",
                "localhost:8000"
            ],
            "django": true,
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONUNBUFFERED": "1",
                "DJANGO_SETTINGS_MODULE": "settings.dev"
            }
        },

        // ---------- Migration ----------
        {
            "name": "Make Migrations",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "makemigrations"
            ],
            "django": true,
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONUNBUFFERED": "1",
                "DJANGO_SETTINGS_MODULE": "settings.dev"
            },
            "presentation": {
                "group": "1-Migration",
                "order": 1
            }
        },
        {
            "name": "Migrate",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/manage.py",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "args": [
                "migrate"
            ],
            "django": true,
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "PYTHONUNBUFFERED": "1",
                "DJANGO_SETTINGS_MODULE": "settings.dev"
            },
            "presentation": {
                "group": "1-Migration",
                "order": 2
            }
        },

